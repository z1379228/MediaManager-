{
  "schema_version": 1,
  "presets": {
    "remux-copy": {
      "strategy": "串流複製封裝（不重新編碼）",
      "extensions": [".mkv", ".mp4", ".mov", ".webm", ".m4a"],
      "estimate_ratio": 1.02,
      "args": ["-map", "0", "-c", "copy"]
    },
    "split-copy": {
      "strategy": "依時間切割並優先串流複製",
      "extensions": [".mkv", ".mp4", ".mov", ".webm", ".m4a", ".mp3", ".flac"],
      "estimate_ratio": 0.5,
      "args": ["-map", "0", "-c", "copy"]
    },
    "join-copy": {
      "strategy": "相同格式串流串接",
      "extensions": [".mkv", ".mp4", ".mov", ".webm", ".m4a", ".mp3", ".flac"],
      "estimate_ratio": 1.01,
      "args": ["-c", "copy"]
    },
    "video-h264": {
      "strategy": "H.264/AAC 相容轉檔",
      "extensions": [".mp4", ".mkv"],
      "estimate_ratio": 0.65,
      "args": ["-map", "0:v:0", "-map", "0:a?", "-c:v", "libx264", "-preset", "medium", "-crf", "23", "-c:a", "aac", "-b:a", "192k"],
      "gpu_args": ["-map", "0:v:0", "-map", "0:a?", "-c:v", "h264_nvenc", "-cq", "23", "-c:a", "aac", "-b:a", "192k"]
    },
    "compress-h265": {
      "strategy": "H.265 壓縮（CPU）",
      "extensions": [".mp4", ".mkv"],
      "estimate_ratio": 0.45,
      "args": ["-map", "0:v:0", "-map", "0:a?", "-c:v", "libx265", "-preset", "medium", "-crf", "28", "-c:a", "aac", "-b:a", "160k"]
    },
    "video-vp9-webm": {
      "strategy": "VP9 / Opus WebM 轉檔",
      "extensions": [".webm"],
      "estimate_ratio": 0.5,
      "args": ["-map", "0:v:0", "-map", "0:a?", "-c:v", "libvpx-vp9", "-crf", "31", "-b:v", "0", "-c:a", "libopus", "-b:a", "128k"]
    },
    "video-mpeg4-avi": {
      "strategy": "MPEG-4 / MP3 AVI 相容轉檔",
      "extensions": [".avi"],
      "estimate_ratio": 0.75,
      "args": ["-map", "0:v:0", "-map", "0:a?", "-c:v", "mpeg4", "-q:v", "4", "-c:a", "libmp3lame", "-b:a", "192k"]
    },
    "audio-mp3": {
      "strategy": "MP3 192 kbps",
      "extensions": [".mp3"],
      "estimate_ratio": 0.15,
      "args": ["-vn", "-c:a", "libmp3lame", "-b:a", "192k"]
    },
    "audio-flac": {
      "strategy": "FLAC 無損音訊",
      "extensions": [".flac"],
      "estimate_ratio": 0.55,
      "args": ["-vn", "-c:a", "flac"]
    },
    "audio-aac": {
      "strategy": "AAC 192 kbps（M4A）",
      "extensions": [".m4a"],
      "estimate_ratio": 0.15,
      "args": ["-vn", "-c:a", "aac", "-b:a", "192k"]
    },
    "audio-opus": {
      "strategy": "Opus 128 kbps",
      "extensions": [".opus"],
      "estimate_ratio": 0.1,
      "args": ["-vn", "-c:a", "libopus", "-b:a", "128k"]
    },
    "audio-wav": {
      "strategy": "WAV PCM 16-bit",
      "extensions": [".wav"],
      "estimate_ratio": 1.0,
      "args": ["-vn", "-c:a", "pcm_s16le"]
    },
    "image-png": {
      "strategy": "靜態影像轉為 PNG",
      "source_extensions": [".jpg", ".jpeg", ".png", ".webp", ".bmp", ".tif", ".tiff"],
      "extensions": [".png"],
      "estimate_ratio": 1.2,
      "args": ["-frames:v", "1", "-update", "1", "-an", "-c:v", "png"]
    },
    "image-jpeg": {
      "strategy": "靜態影像轉為 JPEG（高品質）",
      "source_extensions": [".jpg", ".jpeg", ".png", ".webp", ".bmp", ".tif", ".tiff"],
      "extensions": [".jpg", ".jpeg"],
      "estimate_ratio": 0.5,
      "args": ["-frames:v", "1", "-update", "1", "-an", "-c:v", "mjpeg", "-q:v", "2"]
    },
    "image-webp": {
      "strategy": "靜態影像轉為 WebP",
      "source_extensions": [".jpg", ".jpeg", ".png", ".webp", ".bmp", ".tif", ".tiff"],
      "extensions": [".webp"],
      "estimate_ratio": 0.35,
      "args": ["-frames:v", "1", "-update", "1", "-an", "-c:v", "libwebp", "-q:v", "85"]
    },
    "image-bmp": {
      "strategy": "靜態影像轉為 BMP",
      "source_extensions": [".jpg", ".jpeg", ".png", ".webp", ".bmp", ".tif", ".tiff"],
      "extensions": [".bmp"],
      "estimate_ratio": 1.5,
      "args": ["-frames:v", "1", "-update", "1", "-an", "-c:v", "bmp"]
    },
    "image-tiff": {
      "strategy": "靜態影像轉為 TIFF",
      "source_extensions": [".jpg", ".jpeg", ".png", ".webp", ".bmp", ".tif", ".tiff"],
      "extensions": [".tif", ".tiff"],
      "estimate_ratio": 1.3,
      "args": ["-frames:v", "1", "-update", "1", "-an", "-c:v", "tiff"]
    },
    "subtitle-srt": {
      "strategy": "抽取第一條字幕為 SRT",
      "extensions": [".srt"],
      "estimate_ratio": 0.01,
      "args": ["-map", "0:s:0", "-c:s", "srt"]
    },
    "ad-trim-h264": {
      "strategy": "本機廣告段落剪除（H.264/AAC 新檔）",
      "extensions": [".mp4", ".mkv"],
      "estimate_ratio": 0.9,
      "args": [
        "-map", "0:v:0", "-map", "0:a?",
        "-vf", "@REMOVE_VIDEO_FILTER@",
        "-af", "@REMOVE_AUDIO_FILTER@",
        "-c:v", "libx264", "-preset", "medium", "-crf", "22",
        "-c:a", "aac", "-b:a", "192k"
      ]
    }
  }
}
